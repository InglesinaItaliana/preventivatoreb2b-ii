{
  "compilerOptions": {
    "module": "CommonJS",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2017"
  },
  "compileOnSave": true,
  "include": [
    "index.ts",
    "lib_billing/**/*.ts",
    "lib_md/**/*.ts",
    "lib_mcp/**/*.ts",
    "lib_yjs/**/*.ts"
  ],
  "exclude": [
    "**/__tests__/**"
  ]
}
