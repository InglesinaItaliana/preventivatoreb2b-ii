rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNZIONI HELPER BASATE SU CUSTOM CLAIMS (Nessuna lettura DB!) ---
    
    // Verifica se l'utente ha il claim 'role' impostato su ADMIN
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.role == 'ADMIN') || 
        (request.auth.token.email == 'info@inglesinaitaliana.it')
      );
    }

    // Verifica PRODUZIONE
    function isProduction() {
      return request.auth != null && request.auth.token.role == 'PRODUZIONE';
    }
    
    // Verifica LOGISTICA
    function isLogistics() {
      return request.auth != null && request.auth.token.role == 'LOGISTICA';
    }

    // Helper per il cliente proprietario (invariato)
    function isOwner(resource) {
      return request.auth != null && resource.data.clienteUID == request.auth.uid;
    }

    // --- REGOLE COLLEZIONI ---

    // Collezione TEAM
    match /team/{memberId} {
      // Lettura permessa a chiunque sia loggato (per info UI)
      allow read: if request.auth != null;
      // Scrittura SOLO Admin
      allow write: if isAdmin();
      // Eccezione: ogni membro può aggiornare SOLO il proprio campo fcmTokens
      // (necessario per registrare il token FCM dal browser/PWA)
      allow update: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == memberId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens']);
    }

    // Collezione UTENTI (Clienti)
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Collezione PREVENTIVI / ORDINI
    match /preventivi/{docId} {
      // CHI LEGGE: Admin, Prod, Logistica, Proprietario
      allow read: if isAdmin() || isProduction() || isLogistics() || isOwner(resource);
      
      // CHI SCRIVE:
      allow create: if request.auth != null;
      allow update: if isAdmin() || isProduction() || isLogistics() || isOwner(resource);
      allow delete: if isAdmin();
    }

    // IMPOSTAZIONI
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Configurazione (es. fic, notion) - Protezione extra
    match /config/{docId} {
      allow read, write: if false; // Solo backend (Cloud Functions) accede qui
    }

    // CORE: allowlist email admin (gating sezione CORE / manutenzione)
    // read: tutti gli autenticati; create: bootstrap ruolo ADMIN/super-admin;
    // update/delete: solo super-admin o email già presente nella lista.
    match /core/{docId} {
      allow read:   if request.auth != null;
      allow create: if isAdmin();
      allow update, delete: if request.auth != null && (
        request.auth.token.email == 'info@inglesinaitaliana.it' ||
        (resource.data.emails is list && request.auth.token.email in resource.data.emails)
      );
    }
// REGOLE PER I VIAGGI (TRIPS)
    match /trips/{tripId} {
      // Permetti a chiunque sia loggato di leggere e scrivere i viaggi
      // (Necessario per admin che crea e driver che legge/chiude)
      allow read, write: if request.auth != null;
    }
    // ── SIDERA: Progetti e Task ─────────────────────────────────────────────
    match /projects/{pid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /tasks/{tid} {
        allow read: if request.auth != null;
        allow create: if isAdmin();
        allow update: if isAdmin() ||
          (request.auth != null && resource.data.assignee == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    // Necessario per collectionGroup('tasks') usato in TasksView
    match /{path=**}/tasks/{tid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── PULSAR: standalone tasks (creati da chat/pendenze senza progetto) ────
    match /tasks/{tid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if isAdmin() || (resource.data.createdBy == request.auth.uid);
    }

    // ── PULSAR: Chats e Messages ────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if request.auth != null &&
        request.auth.token.email in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.token.email in resource.data.members;
      allow delete: if request.auth != null &&
        (request.auth.token.email == resource.data.createdBy || isAdmin());

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // L'autore può modificare il proprio messaggio. I membri della chat
        // possono inoltre aggiornare ESCLUSIVAMENTE answeredAt e taskId (per
        // marcare una domanda risposta o linkare un task creato da un altro).
        allow update: if request.auth != null && (
          request.auth.token.email == resource.data.from
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answeredAt', 'taskId'])
            && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
        );
      }
    }

    // Necessario per collectionGroup('messages') usato in PulsarHashtagView
    match /{path=**}/messages/{msgId} {
      allow read: if request.auth != null;
    }

    match /chatHashtags/{tag} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── CEPHEID: Obiettivi (collection root) ────────────────────────────────
    match /obiettivi/{oid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if isAdmin() || (resource.data.createdBy == request.auth.uid);
    }

    // ── QUASAR: Registro attività (audit log, scritto SOLO dalle Cloud Functions) ──
    match /activityLog/{id} {
      allow read:  if request.auth != null;
      allow write: if false;   // Admin SDK (Cloud Functions) bypassa le regole
    }

    // ── NEBULA-DOCS (vedi docs/NEBULA-DOCS.md §3, §9) ───────────────────────
    // Documenti stile Notion. Write SOLO via callable saveDoc (Admin SDK bypassa).
    // Default visibility = 'private' (decisione §12 #1). ACL email in lowercase.
    match /nebulaDocs/{docId} {
      function readerOk(acl) {
        return acl.visibility == 'public'
            || (acl.visibility == 'team' && request.auth.token.email != null)
            || request.auth.token.email in acl.readers
            || request.auth.token.email in acl.writers
            || request.auth.token.email in acl.owners;
      }

      allow read: if request.auth != null && readerOk(resource.data.acl);
      allow write: if false;   // SOLO via callable saveDoc

      match /presence/{userEmail} {
        // Lettura: chiunque autenticato vede chi sta editando (UI presence
        // mostra avatar stack). Scrittura: solo per il proprio record.
        allow read:  if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.token.email == userEmail;
      }

      match /history/{revId} {
        // Stessa ACL del parent. get() = 1 read fatturata, cached per request.
        allow read: if request.auth != null && readerOk(
          get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl
        );
        allow write: if false;   // SOLO snapshot da saveDoc
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}