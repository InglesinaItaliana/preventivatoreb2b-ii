rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNZIONI HELPER BASATE SU CUSTOM CLAIMS (Nessuna lettura DB!) ---
    
    // Verifica se l'utente ha il claim 'role' impostato su ADMIN
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.role == 'ADMIN') || 
        (request.auth.token.email == 'info@inglesinaitaliana.it')
      );
    }

    // Fallback se il custom claim non è ancora refreshato dopo sync /team.
    function isTeamAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/team/$(request.auth.uid))
        && get(/databases/$(database)/documents/team/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isNebulaFleetAdmin() {
      return isAdmin() || isTeamAdmin();
    }

    // Verifica PRODUZIONE
    function isProduction() {
      return request.auth != null && request.auth.token.role == 'PRODUZIONE';
    }
    
    // Verifica LOGISTICA
    function isLogistics() {
      return request.auth != null && request.auth.token.role == 'LOGISTICA';
    }

    // Helper per il cliente proprietario (invariato)
    function isOwner(resource) {
      return request.auth != null && resource.data.clienteUID == request.auth.uid;
    }

    // --- REGOLE COLLEZIONI ---

    // Collezione TEAM
    match /team/{memberId} {
      // Lettura permessa a chiunque sia loggato (per info UI)
      allow read: if request.auth != null;
      // Scrittura SOLO Admin
      allow write: if isAdmin();
      // Eccezione: ogni membro può aggiornare SOLO il proprio campo fcmTokens
      // (necessario per registrare il token FCM dal browser/PWA).
      // Tollerante al re-key /team su UID (docs/STELLA-GRAFO.md): memberId può
      // essere l'email (legacy) o l'uid (post re-key) del chiamante.
      allow update: if request.auth != null
        && (
          (request.auth.token.email != null && request.auth.token.email.lower() == memberId)
          || request.auth.uid == memberId
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens']);
    }

    // Collezione UTENTI (Clienti)
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Collezione PREVENTIVI / ORDINI
    match /preventivi/{docId} {
      // CHI LEGGE: Admin, Prod, Logistica, Proprietario
      allow read: if isAdmin() || isProduction() || isLogistics() || isOwner(resource);
      
      // CHI SCRIVE:
      allow create: if request.auth != null;
      allow update: if isAdmin() || isProduction() || isLogistics() || isOwner(resource);
      allow delete: if isAdmin();
    }

    // IMPOSTAZIONI
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // FUNZIONI/MANSIONI (etichette → categoria + ruolo). Gestite in CORE.
    match /funzioni/{id} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Configurazione (es. fic, notion) - Protezione extra
    match /config/{docId} {
      allow read, write: if false; // Solo backend (Cloud Functions) accede qui
    }

    // CORE: allowlist email admin (gating sezione CORE / manutenzione)
    // read: tutti gli autenticati; create: bootstrap ruolo ADMIN/super-admin;
    // update/delete: solo super-admin o email già presente nella lista.
    match /core/{docId} {
      allow read:   if request.auth != null;
      allow create: if isAdmin();
      allow update, delete: if request.auth != null && (
        request.auth.token.email == 'info@inglesinaitaliana.it' ||
        (resource.data.emails is list && request.auth.token.email in resource.data.emails)
      );
    }
// REGOLE PER I VIAGGI (TRIPS)
    match /trips/{tripId} {
      // (N1 hardening) Lavagna di logistica condivisa: gestita da
      // admin/logistica/produzione. Prima `if request.auth != null` permetteva
      // a QUALUNQUE loggato (clienti inclusi) di leggere/modificare/cancellare
      // i viaggi altrui.
      allow read, write: if isAdmin() || isLogistics() || isProduction();
    }
    // ── SIDERA: Progetti e Task ─────────────────────────────────────────────
    match /projects/{pid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /tasks/{tid} {
        allow read: if request.auth != null;
        allow create: if isAdmin();
        // Hardening (Az.11): admin o proprietario (assegnatario per UID o creatore per UID).
        // Migrazione assignees→UID completata (A5): match solo per uid.
        allow update: if request.auth != null && (
          isAdmin()
          || (resource.data.assignees is list && request.auth.uid in resource.data.assignees)
          || resource.data.createdBy == request.auth.uid
        );
        allow delete: if isAdmin();
      }
    }

    // Necessario per collectionGroup('tasks') usato in TasksView
    match /{path=**}/tasks/{tid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── PULSAR: standalone tasks (creati da chat/pendenze senza progetto) ────
    match /tasks/{tid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // Hardening S1 (Az.11): non più "qualunque loggato". Admin o proprietario
      // (assegnatario per UID o creatore per UID). Migrazione assignees→UID
      // completata (A5): match solo per uid. Gating fine per-ruolo resta lato client.
      allow update: if request.auth != null && (
        isAdmin()
        || (resource.data.assignees is list && request.auth.uid in resource.data.assignees)
        || resource.data.createdBy == request.auth.uid
      );
      allow delete: if isAdmin() || (resource.data.createdBy == request.auth.uid);
    }

    // ── PULSAR: Chats e Messages ────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if request.auth != null &&
        request.auth.token.email in resource.data.members;
      // (N3 hardening) il creatore deve essere se stesso ed essere tra i membri
      // → niente chat intestate ad altri / con membership arbitraria.
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.token.email
        && request.auth.token.email in request.resource.data.members;
      allow update: if request.auth != null &&
        request.auth.token.email in resource.data.members;
      allow delete: if request.auth != null &&
        (request.auth.token.email == resource.data.createdBy || isAdmin());

      match /messages/{msgId} {
        // (N2) Lettura in-chat ristretta ai membri (path diretto). Il chatId è
        // fissato dal path → un solo get(chat) per la query, niente problema
        // "rules≠filtri" (vale per tutti i messaggi della chat in blocco).
        allow read: if request.auth != null
          && request.auth.token.email in
               get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        // (N3 hardening) `from` deve essere il chiamante e il chiamante deve
        // essere membro della chat → niente messaggi firmati a nome altrui.
        // (N2) inoltre il campo `members` denormalizzato — usato dalle rules del
        // collectionGroup — deve essere un SOTTOINSIEME dei membri reali della
        // chat: impedisce di iniettare un messaggio nella ricerca/pendenze di un
        // non-membro scrivendo `members:[vittima]`. Campo assente: tollerato.
        allow create: if request.auth != null
          && request.resource.data.from == request.auth.token.email
          && request.auth.token.email in
               get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && (
            !('members' in request.resource.data)
            || request.resource.data.members.hasOnly(
                 get(/databases/$(database)/documents/chats/$(chatId)).data.members)
          );
        // L'autore può modificare il proprio messaggio. I membri della chat
        // possono inoltre aggiornare ESCLUSIVAMENTE answeredAt, taskId o
        // rejectedAt (marcare risposta, linkare task creato altrove, o
        // rifiutare la proposta di task).
        allow update: if request.auth != null && (
          request.auth.token.email == resource.data.from
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answeredAt', 'taskId', 'rejectedAt'])
            && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
        );
      }
    }

    // (N2) collectionGroup('messages') usato da PulsarHashtagView e
    // PulsarPendingView. La read è concessa solo se il chiamante è tra i
    // `members` denormalizzati sul messaggio. Le due view DEVONO interrogare con
    // `where('members','array-contains', <miaEmail>)` (rules≠filtri): la query
    // si auto-vincola ai messaggi leggibili, e il filtro hashtag/flags avviene
    // lato client (Firestore vieta due operatori su array nella stessa query).
    // I messaggi nuovi scrivono `members` all'invio; gli esistenti via backfill
    // (Cloud Function backfillMessageMembers).
    match /{path=**}/messages/{msgId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.members;
    }

    match /chatHashtags/{tag} {
      allow read: if request.auth != null;
      // (N5 hardening) create/update aperti agli autenticati (l'indice tag è
      // scritto dal client all'invio); delete riservata agli admin per evitare
      // che un utente cancelli/sovrascriva i tag condivisi altrui.
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // ── CEPHEID: Obiettivi (collection root) ────────────────────────────────
    match /obiettivi/{oid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // Hardening S2 (Az.11): admin o creatore (gli obiettivi sono gestiti dagli admin).
      allow update: if request.auth != null && (
        isAdmin() || resource.data.createdBy == request.auth.uid
      );
      allow delete: if isAdmin() || (resource.data.createdBy == request.auth.uid);
    }

    // ── QUASAR: Registro attività (audit log, scritto SOLO dalle Cloud Functions) ──
    match /activityLog/{id} {
      allow read:  if request.auth != null;
      allow write: if false;   // Admin SDK (Cloud Functions) bypassa le regole
    }

    // ── NEBULA-DOCS (vedi docs/NEBULA-DOCS.md §3, §9) ───────────────────────
    // Documenti stile Notion. Write SOLO via callable saveDoc (Admin SDK bypassa).
    // Default visibility = 'private' (decisione §12 #1). ACL email in lowercase.
    match /nebulaDocs/{docId} {
      function readerOk(acl) {
        return acl.visibility == 'public'
            || (acl.visibility == 'team' && request.auth.token.email != null)
            || request.auth.token.email in acl.readers
            || request.auth.token.email in acl.writers
            || request.auth.token.email in acl.owners;
      }

      // Sei stato menzionato in questo doc (refs.users denormalizzato da
      // indexDocRefs)? Allora puoi leggerlo, anche se non in ACL.
      // Semantica: "se ti @menziono ti do accesso al doc implicitamente".
      // Necessario anche per permettere la query collezione "doc dove sono
      // menzionato" (where refs.users array-contains me): senza questo,
      // permission-denied per non-CORE-admin.
      function mentionedIn(d) {
        return 'refs' in d
            && 'users' in d.refs
            && request.auth.token.email in d.refs.users;
      }

      // Writer o owner: può appendere update Yjs (Fase 6) e cursori.
      function writerOk(acl) {
        return request.auth.token.email in acl.writers
            || request.auth.token.email in acl.owners;
      }

      // CORE admin bypass: Fase 1 di NEBULA-DOCS è gated CORE → diamo loro
      // read totale su nebulaDocs così le QUERY (es. LinkedDocsPanel con
      // where('refs.tasks', 'array-contains', id)) passano la pre-validazione
      // del rule engine. Per query non vincolate all'ACL del doc, Firestore
      // non può filtrare per resource.data → senza questo bypass, fail.
      // Quando si rolla NEBULA-DOCS Fase 2 (team-wide), si introdurrà
      // denormalizzazione `acl.readers` o query lato server via callable.
      function isCoreAdminRead() {
        return request.auth.token.email == 'info@inglesinaitaliana.it'
            || request.auth.token.email in get(/databases/$(database)/documents/core/admins).data.get('emails', []);
      }

      allow read: if request.auth != null && (
        isCoreAdminRead()
        || readerOk(resource.data.acl)
        || mentionedIn(resource.data)
      );
      allow write: if false;   // SOLO via callable saveDoc

      match /presence/{userEmail} {
        // Lettura: chiunque autenticato vede chi sta editando (UI presence
        // mostra avatar stack). Scrittura: solo per il proprio record.
        allow read:  if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.token.email == userEmail;
      }

      match /history/{revId} {
        // Stessa ACL del parent. get() = 1 read fatturata, cached per request.
        allow read: if request.auth != null && readerOk(
          get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl
        );
        allow write: if false;   // SOLO snapshot da saveDoc
      }

      // ── Fase 6 (Yjs/CRDT): log delta append-only ─────────────────────────
      // Read: chi può leggere il doc (per convergere). Create: solo writer/owner,
      // con author = se stesso e origin 'client' (server usa Admin → bypassa).
      // Niente update/delete dal client: il log è append-only, la compaction
      // (delete + rebase ydocState) avviene solo via Cloud Function (Admin).
      // get() sul parent = 1 read fatturata per ogni append: costo accettato.
      match /yupdates/{updateId} {
        allow read: if request.auth != null && readerOk(
          get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl
        );
        allow create: if request.auth != null
          && writerOk(get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl)
          && request.resource.data.author == request.auth.token.email
          && request.resource.data.origin == 'client'
          && request.resource.data.keys().hasOnly(['data', 'seq', 'author', 'clientId', 'origin', 'createdAt']);
        allow update, delete: if false;
      }

      // ── Fase 6: cursori live (Awareness) ephemeral ───────────────────────
      // Un doc per client (overwrite). Read: chi legge il doc. Write: chi legge
      // il doc e solo il proprio record (author = se stesso). Delete consentito
      // (cleanup su unmount). TTL via CF awarenessCleanup.
      match /awareness/{clientId} {
        allow read: if request.auth != null && readerOk(
          get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl
        );
        allow write: if request.auth != null
          && readerOk(get(/databases/$(database)/documents/nebulaDocs/$(docId)).data.acl)
          && (request.method == 'delete' || request.resource.data.author == request.auth.token.email);
      }
    }

    // ── NEBULA-DOCS API keys (F4-C2) ────────────────────────────────────────
    // Le chiavi non si leggono né si scrivono dal client. Tutto via callable:
    // generate/revoke/list passano per Admin SDK con check userEmail.
    match /nebulaApiKeys/{keyHash} {
      allow read, write: if false;
    }

    // ── NEBULA-DOCS OAuth 2.0 (F6) ──────────────────────────────────────────
    // Tutto deny-all client. Letture e scritture esclusivamente da
    // Cloud Functions (Admin SDK bypassa rules):
    //   - nebulaOauthClients: scritti da /register (DCR)
    //   - nebulaOauthAuthRequests: scritti da /authorize, letti dalla consent UI
    //     ATTENZIONE: la consent UI legge tramite callable, NON direct. Quindi
    //     deny-all è OK anche per authRequests.
    //   - nebulaOauthCodes: scritti dalla consent callable, letti+eliminati
    //     dal /token endpoint
    //   - nebulaOauthTokens: scritti da /token, validati dal MCP server auth
    match /nebulaOauthClients/{id} { allow read, write: if false; }
    match /nebulaOauthAuthRequests/{id} { allow read, write: if false; }
    match /nebulaOauthCodes/{code} { allow read, write: if false; }
    match /nebulaOauthTokens/{hash} { allow read, write: if false; }

    // ── NEBULA Archivio (file binari) + Mezzi aziendali ─────────────────────
    match /nebulaArchivio/{fileId} {
      allow read: if request.auth != null;
      allow write: if isNebulaFleetAdmin();
    }

    match /nebulaArchivioFolders/{folderId} {
      allow read: if request.auth != null;
      allow write: if isNebulaFleetAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow write: if isNebulaFleetAdmin();
    }

    match /vehicleDeadlines/{deadlineId} {
      allow read: if request.auth != null;
      allow write: if isNebulaFleetAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}